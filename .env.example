# Bay Area RE — environment template
# Copy to .env (gitignored) and fill in real values.
# Never commit .env. Rotate any credential that lands in chat / tickets / docs.

# ── Database ────────────────────────────────────────────────────────────
# Neon Postgres (pooled connection — use for Vercel Functions / app code)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Direct (non-pooled) — use for Alembic migrations only
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Hosting ─────────────────────────────────────────────────────────────
# Vercel deploys the Next.js frontend + Route Handler API
SITE_URL=http://localhost:3000
VERCEL_REGION=pdx1                 # Pin functions to us-west to match Neon region

# Railway hosts the Dagster ETL worker (Phase 2+)
RAILWAY_ENVIRONMENT=development

# ── External data sources ───────────────────────────────────────────────
# FRED API (free; register at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Mapbox (free tier; register at https://account.mapbox.com)
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=          # Public client-side token; restrict by URL in Mapbox dashboard

# GreatSchools (commercial tier required for monetization — Phase 3+)
GREATSCHOOLS_API_KEY=

# Resend for email (Phase 4)
RESEND_API_KEY=

# Upstash Redis (Phase 4+ pub/sub at scale; HTTP API works from Vercel Functions)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 (S3-compatible; Bronze raw payloads + map tiles)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_BRONZE=bayre-bronze
R2_BUCKET_TILES=bayre-tiles

# VAPID web-push keys (Phase 4) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=

# ── App secrets ─────────────────────────────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=

# pgcrypto column-encryption master key (Phase 4)
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
PGCRYPTO_MASTER_KEY=

# ── Vercel Cron secret ──────────────────────────────────────────────────
# Used by Vercel Cron to authenticate scheduled hits to /api/cron/*
CRON_SECRET=
