# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / Next.js (Phase 2+)
node_modules/
.next/
out/
dist/
.turbo/
*.tsbuildinfo

# Exception: @bayre/finance ships a pre-built dist/ so apps/web can import it
# on Vercel without running a workspace-prebuild step. Without this, Vercel
# clones the repo, runs `pnpm install`, then `next build` — and the
# @bayre/finance import fails because dist/ doesn't exist in the clone.
!packages/finance/_ts_export/dist/

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Data / build outputs
# Bronze is intentionally tracked in git through Phase 0 — the adapter caches
# the *filtered* single row per city (~1 KB), not the 1 GB upstream tracker,
# so it stays small and useful as an audit trail. Move to R2 once cumulative
# size > ~50 MB (per docs/runbooks/redfin-csv-source.md).
data/silver/
data/gold/
dashboard/index.html
legacy/dashboard/
legacy/data/

# uv lock (committed) — but keep cached installs out
uv.lock.bak

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Claude Code local settings (user-specific; safe to share `settings.json` only)
.claude/settings.local.json

# Logs
*.log
