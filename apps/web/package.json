{
  "name": "@bayre/web",
  "version": "0.0.0",
  "private": true,
  "description": "Bay Area RE — Next.js 15 frontend (Phase 2 scaffold).",
  "scripts": {
    "dev": "next dev --port 3000",
    "prebuild": "pnpm --filter @bayre/finance run build",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:shadcn-overrides": "bash scripts/check-shadcn-overrides.sh"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0",
    "recharts": "^2.13.0",
    "lucide-react": "^0.460.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "postgres": "^3.4.4",
    "@bayre/finance": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.0"
  }
